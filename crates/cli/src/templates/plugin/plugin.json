{
  "name": "brain",
  "description": "Local-first personal knowledge base with semantic memory, task management, and records for AI agents.",
  "version": "{{version}}",
  "author": {
    "name": "Benedikt Schnatterbeck"
  },
  "license": "MIT",
  "keywords": ["knowledge-base", "task-management", "agent-memory", "semantic-search", "records"],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [{ "type": "command", "command": "brain tasks stats --json 2>/dev/null" }]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [{ "type": "command", "command": "brain tasks stats --json 2>/dev/null" }]
      }
    ]
  }
}
