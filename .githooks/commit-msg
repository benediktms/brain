#!/usr/bin/env sh
# commit-msg hook: validates commit messages follow Conventional Commits.
# Allowed types: feat, fix, refactor, perf, docs, test, chore, ci, build
#
# Valid formats:
#   type: description
#   type(scope): description
#   type!: description          (breaking change)
#   type(scope)!: description   (breaking change with scope)

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Ignore merge commits, fixup/squash commits, and revert commits
case "$commit_msg" in
  Merge\ *|Revert\ *|fixup\!*|squash\!*)
    exit 0
    ;;
esac

# Pattern: type[(scope)][!]: description (non-empty)
pattern='^(feat|fix|refactor|perf|docs|test|chore|ci|build)(\([a-zA-Z0-9_/-]+\))?!?: .+'

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "ERROR: Invalid commit message format."
  echo ""
  echo "  Got: $commit_msg"
  echo ""
  echo "  Expected: <type>[(scope)][!]: <description>"
  echo ""
  echo "  Allowed types: feat, fix, refactor, perf, docs, test, chore, ci, build"
  echo ""
  echo "  Examples:"
  echo "    feat: add hybrid retrieval"
  echo "    fix(brain_lib): handle empty chunks"
  echo "    chore!: drop Python 3.8 support"
  echo ""
  exit 1
fi

exit 0
