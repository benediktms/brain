#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# ── cargo fmt (staged .rs files only) ────────────────────────
STAGED_RS=$(git diff --cached --name-only --diff-filter=ACM -- '*.rs' || true)
if [ -n "$STAGED_RS" ]; then
    if command -v cargo >/dev/null 2>&1; then
        cargo fmt --all -- --check 2>/dev/null
        if [ $? -ne 0 ]; then
            echo "pre-commit: cargo fmt check failed — run 'cargo fmt' and re-stage"
            exit 1
        fi
    fi
fi

# ── Regenerate AGENTS.md + CLAUDE.md (gitignored, local-only) ────
# Both files are per-machine references generated from the init.rs
# template. They are .gitignored, so do NOT stage them — the regen
# step keeps the local copy fresh for AI agents that read the repo.
BIN="${REPO_ROOT}/target/release/brain"
if [ -x "$BIN" ]; then
    "$BIN" docs || true
fi
