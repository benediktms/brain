#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# ── cargo fmt (staged .rs files only) ────────────────────────
STAGED_RS=$(git diff --cached --name-only --diff-filter=ACM -- '*.rs' || true)
if [ -n "$STAGED_RS" ]; then
    if command -v cargo >/dev/null 2>&1; then
        cargo fmt --all -- --check 2>/dev/null
        if [ $? -ne 0 ]; then
            echo "pre-commit: cargo fmt check failed — run 'cargo fmt' and re-stage"
            exit 1
        fi
    fi
fi

# ── Regenerate AGENTS.md ─────────────────────────────────────
BIN="${REPO_ROOT}/target/release/brain"
if [ -x "$BIN" ]; then
    "$BIN" docs
    git add -f AGENTS.md 2>/dev/null || true
fi
